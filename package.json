{
  "name": "odot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A cross-IDE AI coding assistant focused on provider configuration, project selection, and safe code edits.",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "concurrently -k -n server,desktop -c blue,green \"npm run dev:server\" \"npm run dev:desktop\"",
    "dev:server": "tsx watch apps/server/src/index.ts",
    "dev:desktop": "vite --config apps/desktop/vite.config.ts",
    "build": "npm run build:desktop",
    "build:desktop": "npm run typecheck && vite build --config apps/desktop/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:app": "tauri build --no-bundle",
    "tauri:info": "tauri info"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}
