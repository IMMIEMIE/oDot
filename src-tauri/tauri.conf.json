{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "oDot",
  "version": "0.1.0",
  "identifier": "dev.odot.desktop",
  "build": {
    "frontendDist": "../dist/desktop",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:desktop",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "oDot",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "float",
        "title": "",
        "width": 64,
        "height": 64,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
